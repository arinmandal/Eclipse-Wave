	"tokenColors": [
		{
			"name": "Comments",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#9491A8",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Strings",
			"scope": [
				"string",
				"punctuation.definition.string"
			],
			"settings": {
				"foreground": "#3A7A50"
			}
		},
		{
			"name": "Template String Base",
			"scope": [
				"string.template"
			],
			"settings": {
				"foreground": "#3A7A50"
			}
		},
		{
			"name": "Numbers & Booleans",
			"scope": [
				"constant.numeric",
				"constant.language"
			],
			"settings": {
				"foreground": "#B05E20"
			}
		},
		{
			"name": "Keywords",
			"scope": [
				"keyword.control",
				"keyword.other"
			],
			"settings": {
				"foreground": "#7A5FD0",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Storage Types & Modifiers",
			"scope": [
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#7A5FD0",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Logical Operators (&&, ||, !)",
			"scope": [
				"keyword.operator.logical"
			],
			"settings": {
				"foreground": "#8065C0"
			}
		},
		{
			"name": "Comparison Operators (===, !==, >, <)",
			"scope": [
				"keyword.operator.comparison",
				"keyword.operator.relational"
			],
			"settings": {
				"foreground": "#8065C0"
			}
		},
		{
			"name": "Assignment Operators (=, +=, -=)",
			"scope": [
				"keyword.operator.assignment"
			],
			"settings": {
				"foreground": "#8065C0"
			}
		},
		{
			"name": "Arithmetic & Other Operators",
			"scope": [
				"keyword.operator"
			],
			"settings": {
				"foreground": "#8065C0"
			}
		},
		{
			"name": "New Keyword",
			"scope": [
				"keyword.operator.new"
			],
			"settings": {
				"foreground": "#7A5FD0",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Punctuation (Brackets, Commas, Semicolons)",
			"scope": [
				"punctuation.separator",
				"punctuation.terminator",
				"punctuation.section",
				"punctuation.accessor"
			],
			"settings": {
				"foreground": "#8A8499"
			}
		},
		{
			"name": "Function Declarations & Calls",
			"scope": [
				"entity.name.function",
				"meta.function-call",
				"support.function"
			],
			"settings": {
				"foreground": "#2E5FA8"
			}
		},
		{
			"name": "Class & Type Declarations",
			"scope": [
				"entity.name.class",
				"entity.name.type",
				"support.class",
				"support.type"
			],
			"settings": {
				"foreground": "#87642A"
			}
		},
		{
			"name": "Inherited Class",
			"scope": [
				"entity.other.inherited-class"
			],
			"settings": {
				"foreground": "#87642A",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Variables",
			"scope": [
				"variable.other.object",
				"variable.other.readwrite"
			],
			"settings": {
				"foreground": "#B05E20"
			}
		},
		{
			"name": "Object Properties & Keys",
			"scope": [
				"variable.other.property",
				"support.type.property-name"
			],
			"settings": {
				"foreground": "#277A82"
			}
		},
		{
			"name": "Language Constants & Built-ins (this, null, undefined)",
			"scope": [
				"variable.language",
				"support.constant"
			],
			"settings": {
				"foreground": "#C84A20"
			}
		},
		{
			"name": "Function Parameters",
			"scope": [
				"variable.parameter"
			],
			"settings": {
				"foreground": "#87642A",
				"fontStyle": "italic"
			}
		},
		{
			"name": "this / self / super",
			"scope": [
				"variable.language.this",
				"variable.language.self",
				"variable.language.super"
			],
			"settings": {
				"foreground": "#9070E0",
				"fontStyle": "italic"
			}
		},
		{
			"name": "HTML Tags",
			"scope": [
				"entity.name.tag"
			],
			"settings": {
				"foreground": "#A83050"
			}
		},
		{
			"name": "HTML Tag Brackets (< >)",
			"scope": [
				"punctuation.definition.tag.begin",
				"punctuation.definition.tag.end"
			],
			"settings": {
				"foreground": "#A9A4C4"
			}
		},
		{
			"name": "HTML / CSS Attributes",
			"scope": [
				"entity.other.attribute-name",
				"support.type.vendored.property-name"
			],
			"settings": {
				"foreground": "#A0336B"
			}
		},
		{
			"name": "HTML / CSS Attribute Values (quoted strings)",
			"scope": [
				"string.quoted"
			],
			"settings": {
				"foreground": "#3A7A50"
			}
		},
		{
			"name": "CSS Selectors (ID, Class)",
			"scope": [
				"entity.other.attribute-name.id",
				"entity.other.attribute-name.class.css"
			],
			"settings": {
				"foreground": "#87642A"
			}
		},
		{
			"name": "CSS Pseudo-classes (:hover, :focus)",
			"scope": [
				"entity.other.attribute-name.pseudo-class"
			],
			"settings": {
				"foreground": "#A0336B"
			}
		},
		{
			"name": "CSS Pseudo-elements (::before, ::after)",
			"scope": [
				"entity.other.attribute-name.pseudo-element"
			],
			"settings": {
				"foreground": "#A0336B"
			}
		},
