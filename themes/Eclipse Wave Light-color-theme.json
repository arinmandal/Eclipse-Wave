	// === Token Colors (Syntax) ===
	"tokenColors": [
		// ──────────────────────────────────────────────────────────
		//  SECTION 1: CORE ELEMENTS
		//  Basic text, comments, strings, and numbers.
		// ──────────────────────────────────────────────────────────
		{
			"name": "Comments",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#9491A8", // Muted lavender gray
				"fontStyle": "italic"
			}
		},
		{
			"name": "Strings",
			"scope": [
				"string",
				"punctuation.definition.string"
			],
			"settings": {
				"foreground": "#3A7A50" // Deep Aurora Green
			}
		},
		{
			"name": "Numbers and Booleans",
			"scope": [
				"constant.numeric",
				"constant.language"
			],
			"settings": {
				"foreground": "#B05E20" // Warm earthy amber
			}
		},
		// ──────────────────────────────────────────────────────────
		//  SECTION 2: KEYWORDS, STORAGE & OPERATORS
		//  Language keywords, storage types, modifiers, and operators.
		// ──────────────────────────────────────────────────────────
		{
			"name": "Keywords",
			"scope": [
				"keyword.control",
				"keyword.other"
			],
			"settings": {
				"foreground": "#7A5FD0", // Cosmic Violet
				"fontStyle": "italic"
			}
		},
		{
			"name": "Storage Types & Modifiers (e.g., const, let, static, async)",
			"scope": [
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#7A5FD0", // Cosmic Violet
				"fontStyle": "italic"
			}
		},
		{
			"name": "Operators",
			"scope": "keyword.operator",
			"settings": {
				"foreground": "#8065C0" // Muted lavender-purple
			}
		},
		{
			"name": "Punctuation (Brackets, Commas, Semicolons)",
			"scope": [
				"punctuation.separator",
				"punctuation.terminator",
				"punctuation.section",
				"punctuation.accessor"
			],
			"settings": {
				"foreground": "#7A7D94" // Soft slate
			}
		},
		// ──────────────────────────────────────────────────────────
		//  SECTION 3: FUNCTIONS & CLASSES
		//  Declarations, calls, types, and inheritance.
		// ──────────────────────────────────────────────────────────
		{
			"name": "Function Declarations & Calls",
			"scope": [
				"entity.name.function",
				"meta.function-call",
				"support.function"
			],
			"settings": {
				"foreground": "#2E5FA8" // Deep Star Blue
			}
		},
		{
			"name": "Class & Type Declarations",
			"scope": [
				"entity.name.class",
				"entity.name.type",
				"support.class",
				"support.type"
			],
			"settings": {
				"foreground": "#87642A" // Earthy Gold (balanced)
			}
		},
		{
			"name": "Inherited Class",
			"scope": "entity.other.inherited-class",
			"settings": {
				"foreground": "#87642A", // Earthy Gold
				"fontStyle": "italic"
			}
		},
		// ──────────────────────────────────────────────────────────
		//  SECTION 4: VARIABLES, CONSTANTS & PARAMETERS
		//  Variables, properties, constants, and function arguments.
		// ──────────────────────────────────────────────────────────
		{
			"name": "Variables",
			"scope": [
				"variable.other.object",
				"variable.other.readwrite"
			],
			"settings": {
				"foreground": "#B05E20" // Warm earthy amber
			}
		},
		{
			"name": "Object Properties & Keys",
			"scope": [
				"variable.other.property",
				"support.type.property-name"
			],
			"settings": {
				"foreground": "#277A82" // Deep teal
			}
		},
		{
			"name": "Language Constants & Built-in Variables (e.g., 'this', 'null')",
			"scope": [
				"variable.language",
				"support.constant"
			],
			"settings": {
				"foreground": "#C84A20" // Terra orange
			}
		},
		{
			"name": "Function Parameters",
			"scope": "variable.parameter",
			"settings": {
				"foreground": "#87642A", // Earthy Gold
				"fontStyle": "italic"
			}
		},
		// ──────────────────────────────────────────────────────────
		//  SECTION 5: HTML & CSS
		//  Tags, attributes, IDs, and class names.
		// ──────────────────────────────────────────────────────────
		{
			"name": "HTML Tags",
			"scope": "entity.name.tag",
			"settings": {
				"foreground": "#A83050" // Deep Aurora Rose
			}
		},
		{
			"name": "HTML/CSS Attributes",
			"scope": [
				"entity.other.attribute-name",
				"support.type.vendored.property-name"
			],
			"settings": {
				"foreground": "#A0336B" // Nebula pink (darkened)
			}
		},
		{
			"name": "HTML/CSS Attribute Values (e.g. class names)",
			"scope": "string.quoted",
			"settings": {
				"foreground": "#3A7A50" // Deep Aurora Green
			}
		},
		{
			"name": "CSS Selectors (ID, Class)",
			"scope": [
				"entity.other.attribute-name.id",
				"entity.other.attribute-name.class"
			],
			"settings": {
				"foreground": "#87642A" // Earthy Gold
			}
		},
		// ──────────────────────────────────────────────────────────
		//  SECTION 6: MARKDOWN
		//  Specific styles for Markdown files.
		// ──────────────────────────────────────────────────────────
		{
			"name": "Markdown - Headings",
			"scope": "entity.name.section.markdown",
			"settings": {
				"foreground": "#7A5FD0", // Cosmic Violet
				"fontStyle": "bold"
			}
		},
		{
			"name": "Markdown - Bold",
			"scope": "markup.bold.markdown",
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"name": "Markdown - Italic",
			"scope": "markup.italic.markdown",
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"name": "Markdown - Link URL",
			"scope": "markup.underline.link.markdown",
			"settings": {
				"foreground": "#2E5FA8", // Deep Star Blue
				"fontStyle": "underline"
			}
		},
		{
			"name": "Markdown - Inline Code",
			"scope": "markup.inline.raw.string.markdown",
			"settings": {
				"foreground": "#3A7A50" // Deep Aurora Green
			}
		},
		// ──────────────────────────────────────────────────────────
		//  SECTION 7: LANGUAGE SPECIFICS
		//  Rules for specific languages like React (JSX) and Python.
		// ──────────────────────────────────────────────────────────
		{
			"name": "React/JSX - Component Tags",
			"scope": "support.class.component",
			"settings": {
				"foreground": "#8B6400" // Deep Golden Star
			}
		},
		{
			"name": "Python - Decorators",
			"scope": "entity.name.function.decorator",
			"settings": {
				"foreground": "#8065C0" // Muted lavender-purple
			}
		},
		{
			"name": "Python - f-string interpolation",
			"scope": [
				"constant.character.format.placeholder.begin.python",
				"constant.character.format.placeholder.end.python"
			],
			"settings": {
				"foreground": "#C84A20" // Terra Orange
			}
		},
		// ──────────────────────────────────────────────────────────
		//  SECTION 8: INVALID & DEPRECATED
		//  Highlighting for errors and outdated code.
		// ──────────────────────────────────────────────────────────
		{
			"name": "Invalid or Illegal",
			"scope": "invalid.illegal",
			"settings": {
				"foreground": "#CC2244",
				"fontStyle": "italic bold"
			}
		},
		{
			"name": "Deprecated",
			"scope": "invalid.deprecated",
			"settings": {
				"foreground": "#9A7830", // Earthy Gold
				"fontStyle": "italic strikethrough"
			}
		},
		// ──────────────────────────────────────────────────────────
		//  SECTION 9: ADDITIONAL LANGUAGE SUPPORT
		//  Regex, TypeScript types, JSON/YAML, Template strings
		// ──────────────────────────────────────────────────────────
		{
			"name": "Regular Expressions",
			"scope": "string.regexp",
			"settings": {
				"foreground": "#A0336B" // Deep Nebula Pink
			}
		},
		{
			"name": "Escape Characters",
			"scope": "constant.character.escape",
			"settings": {
				"foreground": "#C84A20" // Terra Orange
			}
		},
		{
			"name": "Type Annotations",
			"scope": [
				"entity.name.type.module",
				"support.type.primitive"
			],
			"settings": {
				"foreground": "#277A82" // Deep Teal
			}
		},
		{
			"name": "JSON/YAML Keys",
			"scope": [
				"support.type.property-name.json",
