		{
			"name": "CSS Pseudo-elements (::before, ::after)",
			"scope": [
				"entity.other.attribute-name.pseudo-element"
			],
			"settings": {
				"foreground": "#FF79C6"
			}
		},
		{
			"name": "CSS At-rules (@media, @import, @keyframes)",
			"scope": [
				"keyword.control.at-rule",
				"keyword.at-rule"
			],
			"settings": {
				"foreground": "#9D7CFF",
