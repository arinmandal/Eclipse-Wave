	"tokenColors": [
		{
			"name": "Comments",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#8B8FA8",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Strings",
			"scope": [
				"string",
				"punctuation.definition.string"
			],
			"settings": {
				"foreground": "#A1C682"
			}
		},
		{
			"name": "Template String Base",
			"scope": [
				"string.template"
			],
			"settings": {
				"foreground": "#A1C682"
			}
		},
		{
			"name": "Numbers & Booleans",
			"scope": [
				"constant.numeric",
				"constant.language"
			],
			"settings": {
				"foreground": "#E5A574"
			}
		},
		{
			"name": "Keywords",
			"scope": [
				"keyword.control",
				"keyword.other"
			],
			"settings": {
				"foreground": "#9D7CFF",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Storage Types & Modifiers",
			"scope": [
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#9D7CFF",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Logical Operators (&&, ||, !)",
			"scope": [
				"keyword.operator.logical"
			],
			"settings": {
				"foreground": "#C792EA"
			}
		},
		{
			"name": "Comparison Operators (===, !==, >, <)",
			"scope": [
				"keyword.operator.comparison",
				"keyword.operator.relational"
			],
			"settings": {
				"foreground": "#C792EA"
			}
		},
		{
			"name": "Assignment Operators (=, +=, -=)",
			"scope": [
				"keyword.operator.assignment"
			],
			"settings": {
				"foreground": "#C792EA"
			}
		},
		{
			"name": "Arithmetic & Other Operators",
			"scope": [
				"keyword.operator"
			],
			"settings": {
				"foreground": "#C792EA"
			}
		},
		{
			"name": "New Keyword",
			"scope": [
				"keyword.operator.new"
			],
			"settings": {
				"foreground": "#9D7CFF",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Punctuation (Brackets, Commas, Semicolons)",
			"scope": [
				"punctuation.separator",
				"punctuation.terminator",
				"punctuation.section",
				"punctuation.accessor"
			],
			"settings": {
				"foreground": "#8A929E"
			}
		},
		{
			"name": "Function Declarations & Calls",
			"scope": [
				"entity.name.function",
				"meta.function-call",
				"support.function"
			],
			"settings": {
				"foreground": "#82AAFF"
			}
		},
		{
			"name": "Class & Type Declarations",
			"scope": [
				"entity.name.class",
				"entity.name.type",
				"support.class",
				"support.type"
			],
			"settings": {
				"foreground": "#D7BA7D"
			}
		},
		{
			"name": "Inherited Class",
			"scope": [
				"entity.other.inherited-class"
			],
			"settings": {
				"foreground": "#D7BA7D",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Variables",
			"scope": [
				"variable.other.object",
				"variable.other.readwrite"
			],
			"settings": {
				"foreground": "#E5A574"
			}
		},
		{
			"name": "Object Properties & Keys",
			"scope": [
				"variable.other.property",
				"support.type.property-name"
			],
			"settings": {
				"foreground": "#7CC8DE"
			}
		},
		{
			"name": "Language Constants & Built-ins (this, null, undefined)",
			"scope": [
				"variable.language",
				"support.constant"
			],
			"settings": {
				"foreground": "#F78C6C"
			}
		},
		{
			"name": "Function Parameters",
			"scope": [
				"variable.parameter"
			],
			"settings": {
				"foreground": "#D7BA7D",
				"fontStyle": "italic"
			}
		},
		{
			"name": "this / self / super",
			"scope": [
				"variable.language.this",
				"variable.language.self",
				"variable.language.super"
			],
			"settings": {
				"foreground": "#BD93F9",
				"fontStyle": "italic"
			}
		},
		{
			"name": "HTML Tags",
			"scope": [
				"entity.name.tag"
			],
			"settings": {
				"foreground": "#E17888"
			}
		},
		{
			"name": "HTML Tag Brackets (< >)",
			"scope": [
				"punctuation.definition.tag.begin",
				"punctuation.definition.tag.end"
			],
			"settings": {
				"foreground": "#7C809A"
			}
		},
		{
			"name": "HTML / CSS Attributes",
