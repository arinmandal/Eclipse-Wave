	"tokenColors": [
		{
			"name": "Comments",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#526080",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Strings",
			"scope": [
				"string",
				"punctuation.definition.string"
			],
			"settings": {
				"foreground": "#6DB585"
			}
		},
		{
			"name": "Template String Base",
			"scope": [
				"string.template"
			],
			"settings": {
				"foreground": "#6DB585"
			}
		},
		{
			"name": "Numbers & Booleans",
			"scope": [
				"constant.numeric",
				"constant.language"
			],
			"settings": {
				"foreground": "#D08858"
			}
		},
		{
			"name": "Keywords",
			"scope": [
				"keyword.control",
				"keyword.other"
			],
			"settings": {
				"foreground": "#8478D0",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Storage Types & Modifiers",
			"scope": [
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#8478D0",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Logical Operators (&&, ||, !)",
			"scope": [
				"keyword.operator.logical"
			],
			"settings": {
				"foreground": "#9080C8"
			}
		},
		{
			"name": "Comparison Operators (===, !==, >, <)",
			"scope": [
				"keyword.operator.comparison",
				"keyword.operator.relational"
			],
			"settings": {
				"foreground": "#9080C8"
			}
		},
		{
			"name": "Assignment Operators (=, +=, -=)",
			"scope": [
				"keyword.operator.assignment"
			],
			"settings": {
				"foreground": "#9080C8"
			}
		},
		{
			"name": "Arithmetic & Other Operators",
			"scope": [
				"keyword.operator"
			],
			"settings": {
				"foreground": "#9080C8"
			}
		},
		{
			"name": "New Keyword",
			"scope": [
				"keyword.operator.new"
			],
			"settings": {
				"foreground": "#8478D0",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Punctuation (Brackets, Commas, Semicolons)",
			"scope": [
				"punctuation.separator",
				"punctuation.terminator",
				"punctuation.section",
				"punctuation.accessor"
			],
			"settings": {
				"foreground": "#6080A0"
			}
		},
		{
			"name": "Function Declarations & Calls",
			"scope": [
				"entity.name.function",
				"meta.function-call",
				"support.function"
			],
			"settings": {
				"foreground": "#68A8E0"
			}
		},
		{
			"name": "Class & Type Declarations",
			"scope": [
				"entity.name.class",
				"entity.name.type",
				"support.class",
				"support.type"
			],
			"settings": {
				"foreground": "#B89A60"
			}
		},
		{
			"name": "Inherited Class",
			"scope": [
				"entity.other.inherited-class"
			],
			"settings": {
				"foreground": "#B89A60",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Variables",
			"scope": [
				"variable.other.object",
				"variable.other.readwrite"
			],
			"settings": {
				"foreground": "#D08858"
			}
		},
		{
			"name": "Object Properties & Keys",
			"scope": [
				"variable.other.property",
				"support.type.property-name"
			],
			"settings": {
				"foreground": "#5AAAC0"
			}
		},
		{
			"name": "Language Constants & Built-ins (this, null, undefined)",
			"scope": [
				"variable.language",
				"support.constant"
			],
			"settings": {
				"foreground": "#D07050"
			}
		},
		{
			"name": "Function Parameters",
			"scope": [
				"variable.parameter"
			],
			"settings": {
				"foreground": "#B89A60",
				"fontStyle": "italic"
			}
		},
		{
			"name": "this / self / super",
			"scope": [
				"variable.language.this",
				"variable.language.self",
				"variable.language.super"
			],
			"settings": {
				"foreground": "#90A0F0",
				"fontStyle": "italic"
			}
		},
		{
			"name": "HTML Tags",
			"scope": [
				"entity.name.tag"
			],
			"settings": {
				"foreground": "#C06878"
			}
		},
		{
			"name": "HTML Tag Brackets (< >)",
			"scope": [
				"punctuation.definition.tag.begin",
				"punctuation.definition.tag.end"
			],
			"settings": {
				"foreground": "#4A6080"
			}
		},
		{
			"name": "HTML / CSS Attributes",
			"scope": [
				"entity.other.attribute-name",
				"support.type.vendored.property-name"
			],
			"settings": {
				"foreground": "#C060A0"
			}
		},
		{
			"name": "HTML / CSS Attribute Values (quoted strings)",
			"scope": [
				"string.quoted"
			],
			"settings": {
				"foreground": "#6DB585"
			}
		},
		{
			"name": "CSS Selectors (ID, Class)",
			"scope": [
				"entity.other.attribute-name.id",
				"entity.other.attribute-name.class.css"
			],
			"settings": {
				"foreground": "#B89A60"
			}
		},
		{
			"name": "CSS Pseudo-classes (:hover, :focus)",
			"scope": [
				"entity.other.attribute-name.pseudo-class"
			],
			"settings": {
				"foreground": "#C060A0"
			}
		},
		{
			"name": "CSS Pseudo-elements (::before, ::after)",
			"scope": [
				"entity.other.attribute-name.pseudo-element"
			],
			"settings": {
				"foreground": "#C060A0"
			}
		},
		{
			"name": "CSS At-rules (@media, @import, @keyframes)",
			"scope": [
				"keyword.control.at-rule",
				"keyword.at-rule"
			],
			"settings": {
				"foreground": "#8478D0",
				"fontStyle": "italic"
			}
		},
		{
			"name": "CSS Property Values",
			"scope": [
				"support.constant.property-value",
				"constant.other.color"
			],
			"settings": {
				"foreground": "#D08858"
			}
		},
		{
			"name": "SCSS Variables ($var)",
			"scope": [
