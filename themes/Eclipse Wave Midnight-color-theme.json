				"entity.other.attribute-name.pseudo-element"
			],
			"settings": {
				"foreground": "#D860A8"
			}
		},
		{
			"name": "CSS At-rules (@media, @import, @keyframes)",
			"scope": [
				"keyword.control.at-rule",
				"keyword.at-rule"
			],
			"settings": {
				"foreground": "#8B6EF0",
				"fontStyle": "italic"
			}
		},
		{
			"name": "CSS Property Values",
			"scope": [
				"support.constant.property-value",
				"constant.other.color"
