	"tokenColors": [
		{
			"name": "Comments",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#4A4F68",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Strings",
			"scope": [
				"string",
				"punctuation.definition.string"
			],
			"settings": {
				"foreground": "#8DC76E"
			}
		},
		{
			"name": "Template String Base",
			"scope": [
				"string.template"
			],
			"settings": {
				"foreground": "#8DC76E"
			}
		},
		{
			"name": "Numbers & Booleans",
			"scope": [
				"constant.numeric",
				"constant.language"
			],
			"settings": {
				"foreground": "#D4906A"
			}
		},
		{
			"name": "Keywords",
			"scope": [
				"keyword.control",
				"keyword.other"
			],
			"settings": {
				"foreground": "#8B6EF0",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Storage Types & Modifiers",
			"scope": [
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#8B6EF0",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Logical Operators (&&, ||, !)",
			"scope": [
				"keyword.operator.logical"
			],
			"settings": {
				"foreground": "#B880D5"
			}
		},
		{
			"name": "Comparison Operators (===, !==, >, <)",
			"scope": [
				"keyword.operator.comparison",
				"keyword.operator.relational"
			],
			"settings": {
				"foreground": "#B880D5"
			}
		},
		{
			"name": "Assignment Operators (=, +=, -=)",
			"scope": [
				"keyword.operator.assignment"
			],
			"settings": {
				"foreground": "#B880D5"
			}
		},
		{
			"name": "Arithmetic & Other Operators",
			"scope": [
				"keyword.operator"
			],
			"settings": {
				"foreground": "#B880D5"
			}
		},
		{
			"name": "New Keyword",
			"scope": [
				"keyword.operator.new"
			],
			"settings": {
				"foreground": "#8B6EF0",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Punctuation (Brackets, Commas, Semicolons)",
			"scope": [
				"punctuation.separator",
				"punctuation.terminator",
				"punctuation.section",
				"punctuation.accessor"
			],
			"settings": {
				"foreground": "#70788C"
			}
		},
		{
			"name": "Function Declarations & Calls",
			"scope": [
				"entity.name.function",
				"meta.function-call",
				"support.function"
			],
			"settings": {
				"foreground": "#7BA8F5"
			}
		},
		{
			"name": "Class & Type Declarations",
			"scope": [
				"entity.name.class",
				"entity.name.type",
				"support.class",
				"support.type"
			],
			"settings": {
				"foreground": "#C4A268"
			}
		},
		{
			"name": "Inherited Class",
			"scope": [
				"entity.other.inherited-class"
			],
			"settings": {
				"foreground": "#C4A268",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Variables",
			"scope": [
				"variable.other.object",
				"variable.other.readwrite"
			],
			"settings": {
				"foreground": "#D4906A"
			}
		},
		{
			"name": "Object Properties & Keys",
			"scope": [
				"variable.other.property",
				"support.type.property-name"
			],
			"settings": {
				"foreground": "#68B8CC"
			}
		},
		{
			"name": "Language Constants & Built-ins (this, null, undefined)",
			"scope": [
				"variable.language",
				"support.constant"
			],
			"settings": {
				"foreground": "#E07860"
			}
		},
		{
			"name": "Function Parameters",
			"scope": [
				"variable.parameter"
			],
			"settings": {
				"foreground": "#C4A268",
				"fontStyle": "italic"
			}
		},
		{
			"name": "this / self / super",
			"scope": [
				"variable.language.this",
				"variable.language.self",
				"variable.language.super"
			],
			"settings": {
				"foreground": "#A98CF4",
				"fontStyle": "italic"
			}
		},
		{
			"name": "HTML Tags",
			"scope": [
				"entity.name.tag"
			],
			"settings": {
				"foreground": "#CC7080"
			}
		},
		{
			"name": "HTML Tag Brackets (< >)",
			"scope": [
				"punctuation.definition.tag.begin",
				"punctuation.definition.tag.end"
			],
			"settings": {
				"foreground": "#5E6280"
			}
		},
		{
			"name": "HTML / CSS Attributes",
			"scope": [
				"entity.other.attribute-name",
				"support.type.vendored.property-name"
			],
			"settings": {
				"foreground": "#D860A8"
			}
		},
		{
			"name": "HTML / CSS Attribute Values (quoted strings)",
			"scope": [
				"string.quoted"
			],
			"settings": {
				"foreground": "#8DC76E"
			}
		},
		{
			"name": "CSS Selectors (ID, Class)",
			"scope": [
				"entity.other.attribute-name.id",
				"entity.other.attribute-name.class.css"
			],
			"settings": {
				"foreground": "#C4A268"
			}
		},
		{
			"name": "CSS Pseudo-classes (:hover, :focus)",
